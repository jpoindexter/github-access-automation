# ==========================================
# GitHub Access Automation - Environment Variables
# ==========================================

# Database (Neon PostgreSQL)
# Get this from https://console.neon.tech - include ?sslmode=require
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# GitHub Personal Access Token
# Settings → Developer settings → Personal access tokens → Generate new token (classic)
# Scopes needed: repo
GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"

# GitHub username (your personal account, not org)
GITHUB_ORG_OR_USER="jpoindexter"

# Repository name to invite people to
GITHUB_REPO="fabrk"

# Polar.sh Configuration
# Dashboard → Settings → Webhooks → Copy webhook secret
POLAR_WEBHOOK_SECRET="polar_whs_xxxxxxxxxxxxxxxxxxxxxxxx"
# Dashboard → Settings → API tokens → Generate token
POLAR_ACCESS_TOKEN="polar_oat_xxxxxxxxxxxxxxxxxxxxxxxx"

# Resend Email Service
# Get API key from https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
# Must be a verified sender email in Resend
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# GitHub OAuth (for pre-checkout authentication)
# Create OAuth App at https://github.com/settings/developers
# Settings → Developer settings → OAuth Apps → New OAuth App
GITHUB_OAUTH_CLIENT_ID="Ov23lixxxxxxxxxxxxxxxx"
GITHUB_OAUTH_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Application
# Public URL where your app is hosted
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Environment: development or production
NODE_ENV="development"
# Admin email for error notifications
ADMIN_EMAIL="admin@yourdomain.com"
